WIKI_PATH=./test-vault

# Output language for generated note content (zh = Simplified Chinese, the default; en = English).
# Override per command with --lang. Technical terms and proper nouns (AI, LLM, Prompt, Docker, ...)
# stay in English regardless. Can also be set as "language" in the vault's wiki-config.json.
WIKI_LANG=zh

# Default LLM provider when --provider is omitted (gemini, qwen, deepseek, ollama).
# Defaults to gemini if unset.
WIKI_PROVIDER=gemini

# Physical NIC IP to bind outbound sockets to (for Qwen/DeepSeek under Clash TUN/VPN).
# Find the IPv4 of your real ethernet/wifi adapter (not the virtual TUN one):
#   Windows: `ipconfig`   macOS: `ipconfig getifaddr en0`   Linux: `ip addr` / `hostname -I`
LOCAL_ADDRESS=

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-pro

# Qwen
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-max-preview

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Ollama
OLLAMA_API_KEY=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b
